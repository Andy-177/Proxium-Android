<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 工具栏固定在顶部不滚动 -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
			app:titleTextColor="@android:color/black"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Light" />

        <!-- 滚动内容区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- 转发配置区域 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="端口转发配置"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="本地IP:"
                    android:padding="4dp" />

                <EditText
                    android:id="@+id/et_local_ip"
                    android:layout_width="0dp"
                    android:layout_weight="2"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:text="127.0.0.1"
                    android:padding="4dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="端口:"
                    android:padding="4dp" />

                <EditText
                    android:id="@+id/et_local_port"
                    android:layout_width="0dp"
                    android:layout_weight="2"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:text="11434"
                    android:padding="4dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="目标IP:"
                    android:padding="4dp" />

                <EditText
                    android:id="@+id/et_remote_ip"
                    android:layout_width="0dp"
                    android:layout_weight="2"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:text="192.168.6.99"
                    android:padding="4dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="端口:"
                    android:padding="4dp" />

                <EditText
                    android:id="@+id/et_remote_port"
                    android:layout_width="0dp"
                    android:layout_weight="2"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:text="11434"
                    android:padding="4dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/btn_start"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="启动"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btn_stop"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="停止"
                    android:enabled="false"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- 日志区域 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="日志"
                android:textSize="14sp"
                android:textStyle="bold" />

            <androidx.core.widget.NestedScrollView
                android:id="@+id/sv_log"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="4dp"
                android:background="#f0f0f0"
                android:padding="4dp"
                android:scrollbars="vertical"
                android:fillViewport="true">

                <TextView
                    android:id="@+id/tv_log"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />
            </androidx.core.widget.NestedScrollView>

            <!-- 清空按钮 -->
            <Button
                android:id="@+id/btn_clear"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="清空日志"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp" />

            <!-- 数据包列表标题 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="数据包列表"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_packet_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="数据包: 0" />
            </LinearLayout>

            <!-- 数据包列表表格 -->
            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:layout_marginTop="4dp"
                android:fillViewport="true">

                <HorizontalScrollView
                    android:id="@+id/horizontal_scroll_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="horizontal">

                    <TableLayout
                        android:id="@+id/table_packets"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:stretchColumns="*">

                        <!-- 表头 -->
                        <TableRow
                            android:background="#e0e0e0"
                            android:layout_marginBottom="1dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="0.8"
                                android:padding="8dp"
                                android:text="序号"
                                android:textStyle="bold"
                                android:textSize="11sp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="2"
                                android:padding="8dp"
                                android:text="时间"
                                android:textStyle="bold"
                                android:textSize="11sp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1.2"
                                android:padding="8dp"
                                android:text="方向"
                                android:textStyle="bold"
                                android:textSize="11sp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="0.8"
                                android:padding="8dp"
                                android:text="长度"
                                android:textStyle="bold"
                                android:textSize="11sp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="2.5"
                                android:padding="8dp"
                                android:text="源地址"
                                android:textStyle="bold"
                                android:textSize="11sp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="2.5"
                                android:padding="8dp"
                                android:text="目标地址"
                                android:textStyle="bold"
                                android:textSize="11sp" />
                        </TableRow>

                    </TableLayout>
                </HorizontalScrollView>
            </androidx.core.widget.NestedScrollView>

            <!-- 数据包详情 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="数据包详情"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

            <androidx.core.widget.NestedScrollView
                android:id="@+id/sv_packet_detail"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="4dp"
                android:background="#f0f0f0"
                android:padding="4dp"
                android:scrollbars="vertical"
                android:fillViewport="true">
                
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:scrollbars="horizontal">

                <TextView
                    android:id="@+id/tv_packet_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />
                </HorizontalScrollView>
            </androidx.core.widget.NestedScrollView>

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
