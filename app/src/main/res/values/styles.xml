<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 基础主题 - 使用 NoActionBar 避免与 Toolbar 冲突 -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- 主色调（中紫色） -->
        <item name="colorPrimary">#FFA065CD</item>
        <item name="colorPrimaryDark">#FF8645B3</item>
        <item name="colorAccent">#FF8A52BC</item>

        <!-- 背景色 -->
        <item name="android:windowBackground">@android:color/white</item>

        <!-- 文字颜色 -->
        <item name="android:textColorPrimary">#DE000000</item>
        <item name="android:textColorSecondary">#8A000000</item>

        <!-- EditText 样式 -->
        <item name="colorControlNormal">#FFB0B0B0</item>
        <item name="colorControlActivated">#FFA065CD</item>
        <item name="colorControlHighlight">#33A065CD</item>

        <!-- 按钮样式 -->
        <item name="colorButtonNormal">#FFA065CD</item>
    </style>

    <!-- 按钮样式 - 主要按钮（主色调） -->
    <style name="PrimaryButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@android:color/white</item>
        <item name="android:textColor">#FFA065CD</item>
        <item name="android:textSize">14sp</item>
        <item name="android:padding">8dp</item>
        <item name="android:gravity">center</item>
        <item name="android:backgroundTint">#FFA065CD</item>
        <item name="backgroundTint">#FFA065CD</item>
    </style>

    <!-- 按钮样式 - 次要按钮 -->
    <style name="SecondaryButton" parent="Widget.AppCompat.Button">
        <item name="android:background">#FFE8E8E8</item>
        <item name="android:textColor">#8A000000</item>
        <item name="android:textSize">14sp</item>
        <item name="android:padding">8dp</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- 按钮样式 - 停止按钮（强调色） -->
    <style name="StopButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@android:color/white</item>
        <item name="android:textColor">#FF8A52BC</item>
        <item name="android:textSize">14sp</item>
        <item name="android:padding">8dp</item>
        <item name="android:gravity">center</item>
        <item name="android:backgroundTint">#FF8A52BC</item>
        <item name="backgroundTint">#FF8A52BC</item>
    </style>

    <!-- 清空按钮样式（主色调浅色版本） -->
    <style name="ClearButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@android:color/white</item>
        <item name="android:textColor">#FF8645B3</item>
        <item name="android:textSize">12sp</item>
        <item name="android:padding">6dp</item>
        <item name="android:backgroundTint">#FFA065CD</item>
        <item name="backgroundTint">#FFA065CD</item>
    </style>

    <!-- EditText 样式 -->
    <style name="CustomEditText" parent="Widget.AppCompat.EditText">
        <item name="android:background">@android:color/white</item>
        <item name="android:backgroundTint">#FFA065CD</item>
        <item name="backgroundTint">#FFA065CD</item>
        <item name="android:padding">4dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">#DE000000</item>
        <item name="android:textColorHint">#66000000</item>
    </style>

    <!-- TextView 样式 - 章节标题（强调色） -->
    <style name="SectionTitle">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#FF8A52BC</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <!-- 日志区域 TextView 样式 -->
    <style name="LogText">
        <item name="android:textSize">10sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textColor">#DE000000</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <!-- 表格表头样式（主色调） -->
    <style name="TableHeader">
        <item name="android:background">#FFA065CD</item>
        <item name="android:padding">8dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">#FFFFFFFF</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- 表格单元格样式 -->
    <style name="TableCell">
        <item name="android:padding">6dp</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">#DE000000</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- 表格行样式 - 偶数行 -->
    <style name="TableRowEven">
        <item name="android:background">#FFF3E8FF</item>
    </style>

    <!-- 表格行样式 - 奇数行 -->
    <style name="TableRowOdd">
        <item name="android:background">#FFFFFFFF</item>
    </style>

    <!-- 数据包详情区域样式 -->
    <style name="PacketDetailText">
        <item name="android:textSize">10sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textColor">#DE000000</item>
        <item name="android:lineSpacingExtra">1dp</item>
        <item name="android:padding">2dp</item>
    </style>

    <!-- ScrollView 容器样式 -->
    <style name="ScrollViewContainer">
        <item name="android:background">#FFF3E8FF</item>
        <item name="android:padding">4dp</item>
    </style>

    <!-- 卡片式容器样式 -->
    <style name="CardContainer">
        <item name="android:background">@android:color/white</item>
        <item name="android:padding">12dp</item>
        <item name="android:layout_margin">8dp</item>
        <item name="android:elevation">2dp</item>
    </style>

    <!-- Toolbar 样式覆盖（使用主色调） -->
    <style name="AppTheme.Toolbar" parent="ThemeOverlay.AppCompat.Dark.ActionBar">
        <item name="android:textColorPrimary">#FFFFFFFF</item>
        <item name="android:textColorSecondary">#FFFFFFFF</item>
        <item name="actionMenuTextColor">#FFFFFFFF</item>
    </style>

    <!-- 滚动区域背景样式 -->
    <style name="ScrollAreaBackground">
        <item name="android:background">#FFF3E8FF</item>
        <item name="android:padding">4dp</item>
        <item name="android:scrollbars">vertical</item>
    </style>
</resources>
